# ANIMA ROS2 Bridge — Environment Configuration
# Copy to .env and customize
# Copyright (c) 2026 AIFLOW LABS LIMITED / RobotFlowLabs

# Transport mode: direct_dds | rosbridge
ANIMA_TRANSPORT_MODE=rosbridge

# Rosbridge settings (only used when ANIMA_TRANSPORT_MODE=rosbridge)
ANIMA_ROSBRIDGE_URL=ws://anima_ros2:9090
ANIMA_ROSBRIDGE_RECONNECT=true
ANIMA_ROSBRIDGE_MAX_RECONNECT_ATTEMPTS=10

# Direct DDS settings (only used when ANIMA_TRANSPORT_MODE=direct_dds)
ANIMA_DDS_DOMAIN_ID=0

# Robot identity
ANIMA_ROBOT_NAME=Robot
ANIMA_ROBOT_NAMESPACE=

# Safety limits
ANIMA_MAX_LINEAR_VELOCITY=1.0
ANIMA_MAX_ANGULAR_VELOCITY=1.5

# Logging
ANIMA_LOG_LEVEL=INFO
ANIMA_MCAP_ENABLED=true

# ROS2
ROS_DOMAIN_ID=0
